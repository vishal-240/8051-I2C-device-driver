   6          // ---------- DEBUG PRINT ----------
   7          void debug_msg(char *msg)
   8          {
   9   1          lcd_cmd(0x01);          // clear screen
  10   1          lcd_write_string(msg);
  11   1          msdelay(1000);
  12   1      }
  13          
  14          // ---------- PRINT HEX ----------
  15          void lcd_print_hex(unsigned char val)
  16          {
  17   1          unsigned char high = (val >> 4) & 0x0F;
  18   1          unsigned char low  = val & 0x0F;
  19   1      
  20   1          high += (high < 10) ? '0' : 'A' - 10;
  21   1          low  += (low  < 10) ? '0' : 'A' - 10;
  22   1      
  23   1          lcd_write_char(high);
  24   1          lcd_write_char(low);
  25   1      }
  26          
  27          // ---------- SHOW STATUS ----------
