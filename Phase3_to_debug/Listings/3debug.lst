  35          
  36          // ---------- SAFE READ ----------
  37          unsigned char safe_read(unsigned char dev, unsigned char reg)
  38          {
  39   1          unsigned char val;
  40   1      
  41   1          I2C_Start();
  42   1      
  43   1          I2C_Write((dev << 1) | 0);
