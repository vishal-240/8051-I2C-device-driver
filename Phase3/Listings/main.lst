  31          int get_temp_in_C(long raw_T)
  32          {
  33   1          long var1, var2, t_fine;
  34   1          int T;
  35   1      
  36   1          var1 = ((((raw_T >> 3) - ((long)dig_T1 << 1))) * ((long)dig_T2)) >> 11;
  37   1      
  38   1          var2 = (((((raw_T >> 4) - ((long)dig_T1)) *
  39   1                    ((raw_T >> 4) - ((long)dig_T1))) >>
  40   1                   12) *
  41   1                  ((long)dig_T3)) >>
  42   1                 14;
  43   1      
  44   1          t_fine = var1 + var2;
  45   1      
  46   1          T = (t_fine * 5 + 128) >> 8;
  47   1      
  48   1          return T; // temperature × 100
  49   1      }
